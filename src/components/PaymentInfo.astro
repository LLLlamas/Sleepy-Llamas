---
import { site } from '../config/site';
---

<section class="section payment">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">After your consultation</span>
      <h2>Simple, flexible payment.</h2>
      <p class="lead">
        There&rsquo;s no upfront commitment to reach out. Once we&rsquo;ve
        talked and agreed on a plan, I&rsquo;ll send you an invoice &mdash; pay
        whichever way feels easiest.
      </p>
    </div>

    <div class="payment-grid reveal reveal-delay-1">
      <div class="pay-card">
        <div class="pay-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32"><path d="M6 10h20v14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V10Zm2-4h16a2 2 0 0 1 2 2v2H6V8a2 2 0 0 1 2-2Z" fill="currentColor"/></svg>
        </div>
        <h3>Venmo</h3>
        <p class="pay-handle">{site.venmoHandle}</p>
        <p class="pay-note">Fast, no fees.</p>
      </div>

      <div class="pay-card">
        <div class="pay-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32"><path d="M6 8h20l-4 8 4 8H6l4-8-4-8Z" fill="currentColor"/></svg>
        </div>
        <h3>Zelle</h3>
        <p class="pay-handle">{site.zelleHandle}</p>
        <p class="pay-note">Direct bank-to-bank.</p>
      </div>

      <div class="pay-card">
        <div class="pay-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32"><path d="M4 12a4 4 0 0 1 4-4h16a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-8Zm6 3a1.5 1.5 0 1 0 0 3h12a1.5 1.5 0 1 0 0-3H10Z" fill="currentColor"/></svg>
        </div>
        <h3>Credit Card</h3>
        {site.stripePaymentLink ? (
          <a href={site.stripePaymentLink} class="pay-handle pay-link" target="_blank" rel="noopener">
            Pay with card &rarr;
          </a>
        ) : (
          <p class="pay-handle">Link sent with invoice</p>
        )}
        <p class="pay-note">Secure checkout via Stripe.</p>
      </div>
    </div>

    <p class="payment-footnote reveal reveal-delay-2">
      All payments are discussed after your consultation &mdash; never before.
    </p>

    <!-- Insurance & Benefits -->
    <div class="benefits reveal reveal-delay-3">
      <div class="benefits-inner">
        <div class="benefits-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32"><path d="M16 3l12 5v8c0 7.5-5.4 12.5-12 15-6.6-2.5-12-7.5-12-15V8l12-5Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 16l3 3 7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="benefits-copy">
          <h3>Insurance &amp; Benefits Reimbursement</h3>
          <p>
            Many families use <strong>HSA</strong>, <strong>FSA</strong>, or
            <strong>Carrot Fertility</strong> benefits to cover doula and sleep
            training services. I provide a detailed superbill after each billing
            cycle that you can submit to your plan administrator for reimbursement.
          </p>
          <ul class="benefits-list" role="list">
            <li>
              <strong>HSA / FSA</strong> &mdash; Doula care often qualifies as an
              eligible medical expense. Pay with your HSA/FSA debit card or submit
              your superbill for reimbursement. A Letter of Medical Necessity from
              your OB or midwife can help.
            </li>
            <li>
              <strong>Carrot Fertility</strong> &mdash; If your employer offers
              Carrot benefits, submit my info through your Carrot portal and I&rsquo;ll
              complete the credentialing process. You pay me directly; Carrot
              reimburses you.
            </li>
            <li>
              <strong>Other benefits</strong> &mdash; Some employers offer doula
              stipends or wellness reimbursements. Ask your HR team &mdash; you might
              be surprised!
            </li>
          </ul>
          <p class="benefits-note">
            Not sure if you&rsquo;re covered? Reach out and I&rsquo;ll help you
            figure it out &mdash; no charge, no pressure.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .payment {
    background: var(--color-blush-200);
  }

  .section-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 3rem;
  }
  .section-head .lead { margin-inline: auto; }

  .payment-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    max-width: 900px;
    margin: 0 auto;
  }

  .pay-card {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }
  .pay-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-medium);
  }

  .pay-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--color-blush-200);
    color: var(--color-maroon-700);
    display: grid;
    place-items: center;
    margin: 0 auto 1rem;
  }
  .pay-icon svg { width: 28px; height: 28px; }

  .pay-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
  }

  .pay-handle {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-maroon-700);
    font-weight: 500;
    margin: 0 0 0.4rem;
    word-break: break-all;
  }
  .pay-link {
    display: inline-block;
    border-bottom: 1.5px solid var(--color-maroon-500);
    padding-bottom: 2px;
  }

  .pay-note {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin: 0;
  }

  .payment-footnote {
    margin-top: 2.5rem;
    text-align: center;
    color: var(--color-muted);
    font-size: 0.88rem;
  }

  /* Insurance & Benefits */
  .benefits {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--color-border);
  }
  .benefits-inner {
    display: flex;
    gap: 1.5rem;
    max-width: 780px;
    margin: 0 auto;
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--color-border);
  }
  .benefits-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-blush-200);
    color: var(--color-maroon-700);
    display: grid;
    place-items: center;
  }
  .benefits-icon svg { width: 28px; height: 28px; }
  .benefits-copy h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }
  .benefits-copy p {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .benefits-list li {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.55;
    padding-left: 1.25rem;
    position: relative;
  }
  .benefits-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-maroon-500);
    font-weight: 700;
  }
  .benefits-list li strong {
    color: var(--color-maroon-900);
  }
  .benefits-note {
    font-size: 0.88rem;
    font-style: italic;
    margin-bottom: 0;
  }

  @media (max-width: 760px) {
    .payment-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }
    .benefits-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
