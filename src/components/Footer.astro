---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="brand">
        <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true">
          <circle cx="16" cy="16" r="14" fill="currentColor" opacity="0.12" />
          <path
            d="M22 10c-2 4-6 6-10 5 1 5 6 8 11 6 4-2 6-6 5-10-1-3-4-2-6-1Z"
            fill="currentColor"
          />
        </svg>
        <span>{site.brandName}</span>
      </div>
      <p class="footer-tag">{site.tagline}</p>
    </div>

    <div class="footer-links">
      <div>
        <h4>Explore</h4>
        <ul role="list">
          <li><a href="#about">About</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#process">How It Works</a></li>
          <li><a href="#availability">Availability</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Reach Out</h4>
        <ul role="list">
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href={`tel:${site.phoneHref}`}>{site.phone}</a></li>
          <li><span class="muted">Serving {site.serviceArea}</span></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} {site.brandName}. All rights reserved.</span>
    <span class="muted">Made with warmth.</span>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-maroon-900);
    color: var(--color-blush-100);
    padding-block: 4rem 2rem;
    margin-top: 0;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-blush-100);
  }
  .brand-mark {
    width: 32px;
    height: 32px;
    color: var(--color-maroon-300);
  }
  .footer-tag {
    margin-top: 0.75rem;
    color: var(--color-blush-300);
    max-width: 32ch;
    font-size: 0.95rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer-links h4 {
    font-family: var(--font-body);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-blush-300);
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-links a {
    color: var(--color-blush-100);
    font-size: 0.95rem;
  }
  .footer-links a:hover {
    color: var(--color-maroon-300);
  }
  .muted {
    color: var(--color-blush-300);
    opacity: 0.75;
    font-size: 0.88rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2.5rem;
    margin-top: 2.5rem;
    border-top: 1px solid rgba(253, 246, 244, 0.12);
    font-size: 0.82rem;
    color: var(--color-blush-300);
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
