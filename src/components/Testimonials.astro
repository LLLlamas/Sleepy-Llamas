---
// TODO: replace with real testimonials once collected.
const testimonials = [
  {
    quote:
      'After three nights of working with her, our daughter slept through for the first time in four months. I actually cried. She is magic and gentle and exactly who we needed.',
    author: 'Sarah &amp; Marcus',
    role: 'Parents of a 5-month-old',
  },
  {
    quote:
      'The care and knowledge she brought to our postpartum days was unmatched. I felt seen, rested, and supported in ways I didn&rsquo;t know I needed.',
    author: 'Priya',
    role: 'First-time mom',
  },
  {
    quote:
      'She built a sleep plan around our twins that actually worked for our family. No guilt, no one-size-fits-all. Just real help, every night.',
    author: 'Jenna &amp; Dave',
    role: 'Parents of twins',
  },
];
---

<section class="section testimonials">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Families we&rsquo;ve helped</span>
      <h2>Real stories from real nights.</h2>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <figure class:list={["testimonial", "reveal", `reveal-delay-${i + 1}`]}>
          <svg class="quote-mark" viewBox="0 0 32 32" aria-hidden="true">
            <path d="M10 22V14H4v8h6Zm18 0V14h-6v8h6Z" fill="currentColor" opacity="0.15" />
            <path
              d="M6 20c0-6 3-10 7-11v3c-2 1-4 3-4 6h3v4H6v-2Zm16 0c0-6 3-10 7-11v3c-2 1-4 3-4 6h3v4h-6v-2Z"
              fill="currentColor"
            />
          </svg>
          <blockquote set:html={t.quote}></blockquote>
          <figcaption>
            <span class="author" set:html={t.author}></span>
            <span class="role">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <!-- Referral CTA -->
    <div class="referral reveal reveal-delay-4">
      <p class="referral-text">Know a family that could use a good night&rsquo;s sleep?</p>
      <a
        class="btn btn-secondary referral-btn"
        href={`mailto:?subject=Check out Sleepy Llamas — overnight doula %26 sleep training&body=I wanted to share this with you — Sleepy Llamas offers certified overnight doula care and gentle sleep training in the New York area. They were amazing for us! %0A%0Ahttps://sleepyllamasdoula.com`}
      >
        Share with a friend &hearts;
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--color-blush-200);
  }

  .section-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .testimonial {
    position: relative;
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: 2.25rem 1.75rem 1.75rem;
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--color-border);
    margin: 0;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }
  .testimonial:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-medium);
  }

  .quote-mark {
    width: 40px;
    height: 40px;
    color: var(--color-maroon-500);
    margin-bottom: 0.5rem;
  }

  blockquote {
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--color-maroon-900);
    margin: 0 0 1.5rem;
    font-style: italic;
    font-weight: 400;
  }

  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .author {
    font-weight: 600;
    color: var(--color-maroon-900);
  }
  .role {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .referral {
    text-align: center;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid var(--color-border);
  }
  .referral-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-maroon-900);
    margin-bottom: 1rem;
  }
  .referral-btn {
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 540px;
      margin-inline: auto;
    }
  }
</style>
