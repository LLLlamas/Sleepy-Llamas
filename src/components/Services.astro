---
const services = [
  {
    title: 'Overnight Sleep Training',
    featured: true,
    icon: 'moon',
    tag: 'Most requested',
    description:
      'In-home overnight care tailored to your baby&rsquo;s temperament. I work while you sleep, using gentle, evidence-based methods that build healthy sleep habits for the whole family.',
    bullets: ['Newborn through toddler', 'Gentle, responsive methods', 'Full sleep-plan handoff'],
  },
  {
    title: 'Doula Support',
    featured: false,
    icon: 'heart',
    tag: '',
    description:
      'Birth and postpartum doula services grounded in warmth, non-judgment, and deep experience. I&rsquo;m there for the moments that matter &mdash; before, during, and after.',
    bullets: ['Birth support', 'Postpartum care', 'Newborn guidance'],
  },
  {
    title: 'Consultations',
    featured: false,
    icon: 'chat',
    tag: '',
    description:
      'Not sure what you need yet? A consultation is a calm, no-pressure conversation to help you understand your options and build a plan that actually fits your life.',
    bullets: ['Phone or video', 'Personalized advice', 'No commitment'],
  },
];
---

<section class="section services" id="services">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">What I offer</span>
      <h2>Support, right where you need it.</h2>
      <p class="lead">
        Every service is tailored. No two families sleep alike, and no two
        plans should either.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <article class:list={["service-card", "card", "reveal", `reveal-delay-${i + 1}`, service.featured && 'featured']}>
          {service.tag && <span class="service-tag">{service.tag}</span>}
          <div class="service-icon" aria-hidden="true">
            {service.icon === 'moon' && (
              <svg viewBox="0 0 32 32">
                <path
                  d="M22 6c-2 4-6 6-10 5 1 6 7 10 13 7 5-2 7-8 5-13-1-3-6-2-8 1Z"
                  fill="currentColor"
                />
              </svg>
            )}
            {service.icon === 'heart' && (
              <svg viewBox="0 0 32 32">
                <path
                  d="M16 27s-11-7-11-15a6 6 0 0 1 11-3 6 6 0 0 1 11 3c0 8-11 15-11 15Z"
                  fill="currentColor"
                />
              </svg>
            )}
            {service.icon === 'chat' && (
              <svg viewBox="0 0 32 32">
                <path
                  d="M6 8a4 4 0 0 1 4-4h12a4 4 0 0 1 4 4v9a4 4 0 0 1-4 4h-5l-6 5v-5h-1a4 4 0 0 1-4-4V8Z"
                  fill="currentColor"
                />
              </svg>
            )}
          </div>
          <h3>{service.title}</h3>
          <p set:html={service.description}></p>
          <ul class="service-bullets" role="list">
            {service.bullets.map((b) => <li>{b}</li>)}
          </ul>
          <a href="#contact" class="service-link">Learn more &rarr;</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-blush-200);
  }

  .section-head {
    max-width: 680px;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .section-head .lead {
    margin-inline: auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .service-card.featured {
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-blush-100) 100%);
    border-color: var(--color-maroon-300);
  }

  .service-tag {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-maroon-700);
    color: var(--color-cream);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-blush-200);
    color: var(--color-maroon-700);
    display: grid;
    place-items: center;
    margin-bottom: 1.25rem;
  }
  .featured .service-icon {
    background: var(--color-maroon-700);
    color: var(--color-cream);
  }
  .service-icon svg { width: 26px; height: 26px; }

  .service-card h3 { margin-bottom: 0.5em; }

  .service-bullets {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .service-bullets li {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding-left: 1.1rem;
    position: relative;
  }
  .service-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-maroon-500);
  }

  .service-link {
    margin-top: auto;
    font-weight: 500;
    font-size: 0.95rem;
    align-self: flex-start;
    padding-block: 0.25rem;
    border-bottom: 1.5px solid transparent;
    transition: border-color 0.2s var(--ease-out);
  }
  .service-link:hover {
    border-bottom-color: var(--color-maroon-500);
  }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; }
  }
</style>
