---
import { site } from '../config/site';
---

<section class="section about" id="about">
  <div class="container about-inner">
    <div class="about-portrait reveal">
      <div class="portrait-frame" aria-hidden="true">
        <!-- TODO: replace with a real portrait image -->
        <svg viewBox="0 0 200 240" class="portrait-placeholder">
          <rect width="200" height="240" fill="#f7e6e2" />
          <circle cx="100" cy="90" r="38" fill="#d98295" opacity="0.6" />
          <path d="M40 200c0-35 27-60 60-60s60 25 60 60v40H40Z" fill="#d98295" opacity="0.6" />
        </svg>
      </div>
      <div class="portrait-tag">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 2l2.5 6 6.5.5-5 4.5 1.5 6.5L12 16l-5.5 3.5L8 13 3 8.5 9.5 8 12 2z"
            fill="currentColor"
          />
        </svg>
        <span>Certified &amp; Trusted</span>
      </div>
    </div>

    <div class="about-copy reveal reveal-delay-1">
      <span class="eyebrow">About {site.brandName}</span>
      <h2>Warm, expert support through the seasons that matter most.</h2>
      <p class="lead">
        <!-- TODO: replace with real bio -->
        With years of hands-on experience supporting new families, I combine
        evidence-based sleep methods with the kind of gentle, intuitive care
        that only comes from truly listening. Every family is different, and
        every plan is yours alone.
      </p>

      <ul class="credentials" role="list">
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="check">
            <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Certified Postpartum Doula <em>(TODO)</em></span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="check">
            <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Infant Sleep Consultant <em>(TODO)</em></span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="check">
            <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>CPR &amp; Safe Sleep Trained</span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="check">
            <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Background Checked &amp; Insured</span>
        </li>
      </ul>

      <a href="#contact" class="btn btn-secondary">Let&rsquo;s talk</a>
    </div>
  </div>

  <!-- Families we've helped — inline testimonials -->
  <div class="container about-testimonials reveal">
    <span class="eyebrow">Families we&rsquo;ve helped</span>
    <div class="about-quotes">
      <figure class="about-quote reveal reveal-delay-1">
        <blockquote>After three nights of working with her, our daughter slept through for the first time in four months. I actually cried.</blockquote>
        <figcaption>&mdash; Sarah &amp; Marcus, <span>parents of a 5-month-old</span></figcaption>
      </figure>
      <figure class="about-quote reveal reveal-delay-2">
        <blockquote>The care and knowledge she brought to our postpartum days was unmatched. I felt seen, rested, and supported in ways I didn&rsquo;t know I needed.</blockquote>
        <figcaption>&mdash; Priya, <span>first-time mom</span></figcaption>
      </figure>
      <figure class="about-quote reveal reveal-delay-3">
        <blockquote>She built a sleep plan around our twins that actually worked for our family. No guilt, no one-size-fits-all. Just real help, every night.</blockquote>
        <figcaption>&mdash; Jenna &amp; Dave, <span>parents of twins</span></figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-blush-100);
  }
  .about-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .about-portrait {
    position: relative;
    justify-self: center;
    width: 100%;
    max-width: 360px;
  }
  .portrait-frame {
    position: relative;
    aspect-ratio: 5 / 6;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-medium);
    background: var(--color-blush-200);
    transform: rotate(-1.5deg);
    transition: transform 0.4s var(--ease-out);
  }
  .about-portrait:hover .portrait-frame {
    transform: rotate(0deg);
  }
  .portrait-placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }
  .portrait-tag {
    position: absolute;
    bottom: -18px;
    right: -12px;
    background: var(--color-maroon-700);
    color: var(--color-cream);
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    box-shadow: var(--shadow-lift);
  }
  .portrait-tag svg {
    width: 16px;
    height: 16px;
    color: var(--color-gold);
  }

  .about-copy h2 {
    margin-bottom: 0.6em;
  }

  .credentials {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 1.25rem;
  }
  .credentials li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: var(--color-ink);
  }
  .credentials em {
    color: var(--color-muted);
    font-style: normal;
    font-size: 0.8rem;
  }
  .check {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--color-maroon-500);
    margin-top: 1px;
  }

  /* Inline testimonials in About */
  .about-testimonials {
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .about-quotes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2.5vw, 1.5rem);
    margin-top: 1.75rem;
  }

  .about-quote {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem 1.25rem;
    margin: 0;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    text-align: left;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }
  .about-quote:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-medium);
  }

  .about-quote blockquote {
    font-family: var(--font-display);
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--color-maroon-900);
    margin: 0 0 1rem;
    font-style: italic;
    font-weight: 400;
  }

  .about-quote figcaption {
    font-size: 0.82rem;
    color: var(--color-muted);
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .about-quote figcaption span {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
    opacity: 0.8;
    margin-top: 0.15rem;
  }

  @media (max-width: 860px) {
    .about-inner {
      grid-template-columns: 1fr;
    }
    .credentials { grid-template-columns: 1fr; }
    .about-portrait { max-width: 280px; }
    .about-quotes { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
  }
</style>
