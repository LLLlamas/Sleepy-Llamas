---
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.brandName} — ${site.tagline}`,
  description = site.shortDescription,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6b1a28" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{title}</title>

    <!-- Fonts: Fraunces (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- Open Graph basics -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Additional SEO meta -->
    <meta name="keywords" content="overnight doula NYC, baby sleep training New York, postpartum doula, overnight newborn care, gentle sleep training, night doula Manhattan, Brooklyn doula, overnight baby care, certified doula NYC, sleep consultant New York" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://sleepyllamasdoula.com" />

    <!-- JSON-LD: ProfessionalService (local business) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": site.brandName,
      "description": site.shortDescription,
      "url": "https://sleepyllamasdoula.com",
      "email": site.email,
      "telephone": site.phone,
      "priceRange": "$$",
      "areaServed": [
        { "@type": "City", "name": "New York City" },
        { "@type": "Borough", "name": "Manhattan" },
        { "@type": "Borough", "name": "Brooklyn" },
        { "@type": "Borough", "name": "Queens" },
        { "@type": "Borough", "name": "Bronx" },
        { "@type": "Borough", "name": "Staten Island" },
        { "@type": "AdministrativeArea", "name": "Westchester County" }
      ],
      "serviceType": [
        "Overnight Doula Support",
        "Overnight Baby Sleep Training",
        "Postpartum Doula Care",
        "Newborn Sleep Consultation"
      ],
      "knowsAbout": [
        "Gentle sleep training",
        "Postpartum recovery support",
        "Newborn overnight care",
        "Infant sleep consulting",
        "Breastfeeding support"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Overnight Care Packages",
        "itemListElement": [
          { "@type": "Offer", "name": "Starter Package — 4 Nights", "price": "2480", "priceCurrency": "USD" },
          { "@type": "Offer", "name": "Standard Package — 8 Nights", "price": "4800", "priceCurrency": "USD" },
          { "@type": "Offer", "name": "Extended Package — 12 Nights", "price": "6900", "priceCurrency": "USD" },
          { "@type": "Offer", "name": "Comprehensive Package — 16 Nights", "price": "9000", "priceCurrency": "USD" }
        ]
      }
    })} />

    <!-- JSON-LD: FAQPage (enables rich results in Google) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What age is right for sleep training?", "acceptedAnswer": { "@type": "Answer", "text": "Most babies are ready for gentle sleep-shaping between 4 and 6 months, but supportive habits can begin from birth. During our consultation we'll discuss what's appropriate for your baby's age, temperament, and feeding needs." }},
        { "@type": "Question", "name": "Is it safe to sleep train? Will my baby cry it out?", "acceptedAnswer": { "@type": "Answer", "text": "Safety is the foundation of everything I do. I use gentle, responsive methods — not cry-it-out. Every plan follows safe-sleep guidelines and respects your baby's emotional needs." }},
        { "@type": "Question", "name": "What exactly does a doula do?", "acceptedAnswer": { "@type": "Answer", "text": "A doula provides non-medical physical, emotional, and informational support before, during, and after birth. I focus on postpartum and overnight support, helping your family rest, heal, and bond in those early weeks." }},
        { "@type": "Question", "name": "What's the difference between a night nurse and an overnight doula?", "acceptedAnswer": { "@type": "Answer", "text": "A night nurse typically focuses on medical-style newborn care, while an overnight doula provides holistic postpartum support — including emotional guidance, breastfeeding help, and sleep-shaping alongside nighttime baby care." }},
        { "@type": "Question", "name": "Can I use my HSA or FSA to pay for doula services?", "acceptedAnswer": { "@type": "Answer", "text": "Many families use HSA or FSA funds to cover doula care — it often qualifies as an eligible medical expense. Check with your plan administrator to confirm your specific coverage." }},
        { "@type": "Question", "name": "What areas do you serve in New York?", "acceptedAnswer": { "@type": "Answer", "text": "Overnight doula support and sleep training throughout the NYC metro area, including Manhattan, Brooklyn, Queens, the Bronx, Staten Island, and parts of Westchester and northern New Jersey." }},
        { "@type": "Question", "name": "What happens during an overnight visit?", "acceptedAnswer": { "@type": "Answer", "text": "I typically arrive between 8–10 PM and stay through 6–7 AM. During the night, I handle all feedings, diaper changes, soothing, and sleep training as needed. In the morning, I leave a brief log of how the night went." }}
      ]
    })} />
  </head>
  <body>
    <slot />

    <!-- Scroll reveal: add .in-view when an element with .reveal enters the viewport -->
    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduceMotion && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      } else {
        // Reduced motion or no IO support — show everything immediately
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
      }
    </script>
  </body>
</html>
